
// ─────────────────────────────────────────────────────────────────────────────
// ENTERPRISE TEMPLATE MANAGEMENT SYSTEM
// ─────────────────────────────────────────────────────────────────────────────

model RnServiceTemplate {
  id                 String    @id @default(cuid())
  name               String
  description        String?
  category           String
  pricingModel       String    @default("FIXED")
  baseCurrency       String    @default("USD")
  taxRate            Float     @default(0)
  discountRules      Json      @default("[]")
  termsAndConditions String?
  isActive           Boolean   @default(true)
  version            Int       @default(1)
  originalId         String?

  milestoneTemplates  RnMilestoneTemplate[]
  deliverableTemplates RnDeliverableTemplate[]
  onboardingTemplates RnOnboardingTemplate[]
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?
}

model RnMilestoneTemplate {
  id                    String   @id @default(cuid())
  serviceTemplateId     String
  title                 String
  description           String?
  order                 Int
  estimatedDurationDays Int      @default(7)
  paymentPercentage     Float    @default(0)
  clientApprovalRequired Boolean @default(false)
  
  serviceTemplate       RnServiceTemplate @relation(fields: [serviceTemplateId], references: [id], onDelete: Cascade)
  taskTemplates         RnTaskTemplate[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model RnTaskTemplate {
  id                  String   @id @default(cuid())
  milestoneTemplateId String
  title               String
  priority            String   @default("MEDIUM")
  estimatedHours      Float    @default(0)

  milestoneTemplate   RnMilestoneTemplate @relation(fields: [milestoneTemplateId], references: [id], onDelete: Cascade)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RnDeliverableTemplate {
  id                  String   @id @default(cuid())
  serviceTemplateId   String
  milestoneTemplateId String?
  label               String
  format              String   @default("PDF")

  serviceTemplate     RnServiceTemplate @relation(fields: [serviceTemplateId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RnOnboardingTemplate {
  id                  String   @id @default(cuid())
  serviceTemplateId   String
  welcomeMessage      String?
  requiresNda         Boolean  @default(false)
  requiredDocuments   Json     @default("[]")

  serviceTemplate     RnServiceTemplate @relation(fields: [serviceTemplateId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RnEmailTemplate {
  id                  String   @id @default(cuid())
  triggerEvent        String   @unique
  subject             String
  htmlBody            String
  availableVariables  Json     @default("[]")
  isActive            Boolean  @default(true)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
