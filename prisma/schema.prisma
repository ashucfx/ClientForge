// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClientType {
  FRESHER
  MID_CAREER
  EXECUTIVE
  EXECUTIVE_PLUS
  AGENCY_CLIENT  // NEW — Ripple Nexus agency service clients
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
  VIEWER
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  brandAccess  String[]  @default(["catalyst", "ripple_nexus"]) // RBAC brand isolation
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}


enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
  EXPIRED
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique

  // Client Info
  clientName    String
  clientEmail   String
  clientPhone   String
  clientType    ClientType
  country       String
  companyName   String?

  // Currency
  currency       String
  currencySymbol String
  exchangeRate   Float

  // ── Line items (new flexible model) ──────────
  // JSON array of { id, description, qty, unitPrice, lineTotal }
  lineItems Json @default("[]")

  // Invoice-level adjustments
  discountRate   Float @default(0)   // % discount applied on subtotal
  taxRate        Float @default(0)   // % tax applied after discount
  discountAmount Float @default(0)   // computed
  taxAmount      Float @default(0)   // computed

  // ── Legacy service fields (backward compat) ──
  resumeBaseInr        Float @default(0)
  linkedinBaseInr      Float @default(0)
  coverLetterBaseInr   Float @default(0)
  resumeConverted      Float @default(0)
  linkedinConverted    Float @default(0)
  coverLetterConverted Float @default(0)

  // Totals
  subtotalConverted      Float
  processingFeeRate      Float
  processingFeeConverted Float
  totalPayable           Float

  // Revisions
  revisionCount  Int   @default(0)
  revisionCharge Float @default(0)

  // Meta
  notes         String?
  customPricing Boolean @default(false)

  // Payment
  status            InvoiceStatus @default(PENDING)
  razorpayLinkId    String?
  razorpayLinkUrl   String?
  razorpayPaymentId String?
  paidAt            DateTime?

  // Dates
  invoiceDate DateTime @default(now())
  dueDate     DateTime

  // Payment gateway
  paymentGateway   String  @default("RAZORPAY") // "RAZORPAY" | "PAYPAL"
  paypalInvoiceId  String?
  paypalPaymentUrl String?

  // Split / installment payment
  installmentPlan  Boolean @default(false)
  installmentCount Int     @default(1)      // 1 = single, 2 = two parts, 3 = three parts
  installments     Json    @default("[]")   // Installment[]

  // Email
  emailSentAt      DateTime?
  emailResendCount Int @default(0)

  // ── Brand context (NEW — additive, @default ensures all existing invoices = 'catalyst') ──
  // 'catalyst'     → Career Booster invoice — Catalyst branding, Catalyst email theme
  // 'ripple_nexus' → Agency invoice — Ripple Nexus branding, RN email theme
  brandId          String @default("catalyst")
  rnServiceId      String? // For Ripple Nexus: which service module this invoice is for

  @@index([brandId])

  // ── Relational Data (New Phase 3) ──────────
  invoiceLineItems    InvoiceLineItem[]
  invoiceInstallments InvoiceInstallment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clientType])
  @@index([clientEmail])
  @@index([paymentGateway])
}

model ExchangeRateCache {
  id             String   @id @default(cuid())
  baseCurrency   String   @default("INR")
  targetCurrency String
  rate           Float
  cachedAt       DateTime @default(now())
  expiresAt      DateTime

  @@unique([baseCurrency, targetCurrency])
}

// ─────────────────────────────────────────────────────────────────────────────
// CAREER BOOSTER MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum CareerPackage {
  RESUME
  LINKEDIN
  COVER_LETTER
  FULL
}

// Dynamic services — seeded; new clients use CareerClientService
model CareerService {
  id       String  @id @default(cuid())
  slug     String  @unique  // RESUME | COVER_LETTER | LINKEDIN | PORTFOLIO | FULL_PACKAGE
  name     String
  formType String? // career_profile | linkedin_profile | portfolio_website | null

  clients CareerClientService[]
}

model CareerClientService {
  id        String   @id @default(cuid())
  clientId  String
  serviceId String
  createdAt DateTime @default(now())

  client  CareerClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service CareerService @relation(fields: [serviceId], references: [id])

  @@unique([clientId, serviceId])
  @@index([clientId])
}

enum CareerStatus {
  NOT_STARTED
  SUBMITTED
  UNDER_PROCESS
  DRAFT_SENT
  REVISION_REQUESTED
  COMPLETED
}

model CareerClient {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  phone             String?
  packageType       CareerPackage? // deprecated: use services relation
  status            CareerStatus   @default(NOT_STARTED)
  amountPaid        Float         @default(0)
  currency          String        @default("INR")
  razorpayPaymentId String?       @unique
  razorpayOrderId   String?
  magicToken        String?
  magicTokenExpiry  DateTime?
  pinHash           String?       // HMAC-SHA256 of 6-digit PIN
  lastLoginAt       DateTime?
  invoiceId         String?
  notes               String?
  expectedDeliveryAt  DateTime?
  draftSentAt         DateTime?
  completedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  forms        CareerFormSubmission[]
  deliverables CareerDeliverable[]
  emailLogs    CareerEmailLog[]
  activityLogs CareerActivityLog[]
  revisions    CareerRevision[]
  comments     CareerComment[]
  services     CareerClientService[]
  messages     CareerMessage[]
  deleteOtp    CareerDeleteOtp?

  @@index([status])
  @@index([email])
  @@index([packageType])
}

model CareerFormSubmission {
  id          String       @id @default(cuid())
  clientId    String
  formType    String
  formData    Json
  version     Int          @default(1)
  submittedAt DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, formType])
}

model CareerDeliverable {
  id           String   @id @default(cuid())
  clientId     String
  label        String
  fileUrl      String
  publicId     String
  fileType     String
  mimeType     String
  sizeBytes    Int      @default(0)
  originalName String   @default("")
  fileCategory String   @default("final") // "draft" | "final"
  resourceType String   @default("raw")   // "raw" | "image" | "video"
  uploadedBy   String
  emailSent    Boolean  @default(false)
  createdAt    DateTime @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, fileCategory])
}

model CareerEmailLog {
  id        String       @id @default(cuid())
  clientId  String
  trigger   String
  resendId  String?
  status    String       @default("sent")
  metadata  Json?
  sentAt    DateTime     @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, trigger, status])
}

model CareerActivityLog {
  id          String       @id @default(cuid())
  clientId    String
  action      String
  performedBy String       @default("system")
  metadata    Json?
  createdAt   DateTime     @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerFormSchema {
  id        String   @id @default(cuid())
  formType  String   @unique
  schema    Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model CareerRevision {
  id          String   @id @default(cuid())
  clientId    String
  requestedBy String   @default("client") // "client" | "admin"
  note        String
  fileLabel   String?  // which deliverable this relates to
  status      String   @default("PENDING") // PENDING | APPROVED | DENIED
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerComment {
  id             String    @id @default(cuid())
  clientId       String
  authorType     String    @default("client") // "client" | "admin"
  authorName     String
  content        String
  attachments    Json?     // {name,url,mimeType,size}[]
  readByAdmin    Boolean   @default(false)
  readByClient   Boolean   @default(false)
  readByAdminAt  DateTime?
  readByClientAt DateTime?
  createdAt      DateTime  @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerMessage {
  id            String   @id @default(cuid())
  clientId      String
  authorType    String   @default("client") // "client" | "admin"
  authorName    String
  content       String
  readByAdmin   Boolean  @default(false)
  readByClient  Boolean  @default(false)
  createdAt     DateTime @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerDeleteOtp {
  id        String       @id @default(cuid())
  clientId  String       @unique
  otpHash   String       // SHA-256 of 6-digit OTP
  expiresAt DateTime
  createdAt DateTime     @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// RELATIONAL INVOICE STRUCTURES (PHASE 3)
// ─────────────────────────────────────────────────────────────────────────────

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  qty         Int
  unitPrice   Float
  lineTotal   Float
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceInstallment {
  id          String   @id @default(cuid())
  invoiceId   String
  seq         Int      // e.g. 1, 2, 3
  amount      Float
  dueDate     DateTime
  status      String   @default("PENDING") // PENDING, PAID, CANCELLED, EXPIRED
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RELIABILITY & QUEUES (PHASE 2)
// ─────────────────────────────────────────────────────────────────────────────

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // e.g., 'RAZORPAY', 'PAYPAL'
  eventId     String   @unique // The unique ID from the provider (e.g., razorpay_payment_id or event_id)
  eventType   String   // e.g., 'payment.captured'
  payload     Json     // The raw payload
  status      String   @default("PROCESSED") // 'PROCESSED', 'FAILED'
  error       String?
  createdAt   DateTime @default(now())

  @@index([provider, eventId])
}

model EmailQueue {
  id          String   @id @default(cuid())
  to          String
  trigger     String
  clientId    String?
  data        Json?    // Email template data
  status      String   @default("PENDING") // 'PENDING', 'PROCESSING', 'SENT', 'FAILED'
  error       String?
  attempts    Int      @default(0)
  nextRunAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, nextRunAt])
  @@index([clientId, trigger])
}


// ─────────────────────────────────────────────────────────────────────────────
// RIPPLE NEXUS MODULE  [NEW — all tables below are additive, zero impact on existing]
// Career* tables above are 100% untouched.
// ─────────────────────────────────────────────────────────────────────────────

// Service modules — defines the workflow stages and policies for each RN service
model RnServiceModule {
  id             String   @id @default(cuid())
  slug           String   @unique  // 'web_development' | 'seo_optimization' | 'ai_automation' | 'branding' | 'saas_development' | 'consulting' | 'marketing'
  name           String            // "Website Development"
  workflowStages Json              // string[] — ordered stage names e.g. ["DISCOVERY","WIREFRAME","DESIGN","DEVELOPMENT","QA","LAUNCHED"]
  revisionLimit  Int      @default(3)
  revisionCharge Float    @default(0)   // extra revision charge in INR base
  defaultSlaDays Int      @default(30)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clients        RnClient[]

  @@index([slug])
}

// Ripple Nexus agency clients — completely separate from CareerClient
model RnClient {
  id               String    @id @default(cuid())
  name             String
  email            String
  phone            String?
  country          String?
  companyName      String?
  serviceModuleId  String

  // Workflow state
  currentStage     String    @default("NOT_STARTED")
  completedStages  Json      @default("[]")   // string[]
  stageEnteredAt   DateTime  @default(now())

  // Payment reference
  invoiceId        String?
  amountPaid       Float     @default(0)
  currency         String    @default("INR")

  // Portal access
  magicToken       String?
  magicTokenExpiry DateTime?
  pinHash          String?   // HMAC-SHA256 of 6-digit PIN
  lastLoginAt      DateTime?

  // Project timeline
  expectedDeliveryAt DateTime?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  serviceModule    RnServiceModule      @relation(fields: [serviceModuleId], references: [id])
  forms            RnFormSubmission[]
  deliverables     RnDeliverable[]
  revisions        RnRevision[]
  messages         RnMessage[]
  emailLogs        RnEmailLog[]
  activityLogs     RnActivityLog[]
  deleteOtp        RnDeleteOtp?

  @@index([email])
  @@index([serviceModuleId, currentStage])
}

model RnFormSubmission {
  id          String   @id @default(cuid())
  clientId    String
  formSlug    String   // 'discovery' | 'requirements' | 'feedback'
  formData    Json
  version     Int      @default(1)
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnDeliverable {
  id           String   @id @default(cuid())
  clientId     String
  label        String
  fileUrl      String
  publicId     String
  fileType     String
  mimeType     String
  sizeBytes    Int      @default(0)
  originalName String   @default("")
  fileCategory String   @default("final")   // 'draft' | 'milestone' | 'final'
  resourceType String   @default("raw")    // 'raw' | 'image' | 'video'
  stageContext String?                      // which workflow stage this belongs to
  uploadedBy   String
  emailSent    Boolean  @default(false)
  createdAt    DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, fileCategory])
}

model RnRevision {
  id           String   @id @default(cuid())
  clientId     String
  requestedBy  String   @default("client")  // 'client' | 'admin'
  note         String
  fileLabel    String?
  status       String   @default("PENDING") // 'PENDING' | 'APPROVED' | 'DENIED'
  adminNote    String?
  chargeAmount Float    @default(0)          // 0 = free revision within limit
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnMessage {
  id           String   @id @default(cuid())
  clientId     String
  authorType   String   @default("client")  // 'client' | 'admin'
  authorName   String
  content      String
  attachments  Json?    // {name,url,mimeType,size}[]
  readByAdmin  Boolean  @default(false)
  readByClient Boolean  @default(false)
  createdAt    DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnEmailLog {
  id       String   @id @default(cuid())
  clientId String
  trigger  String
  resendId String?
  status   String   @default("sent")  // 'sent' | 'failed'
  metadata Json?
  sentAt   DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, trigger, status])
}

model RnActivityLog {
  id          String   @id @default(cuid())
  clientId    String
  action      String
  performedBy String   @default("system")
  metadata    Json?
  createdAt   DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnDeleteOtp {
  id        String   @id @default(cuid())
  clientId  String   @unique
  otpHash   String   // SHA-256 of 6-digit OTP
  expiresAt DateTime
  createdAt DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// ENTERPRISE AUDIT & SECURITY (PHASE 3)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String   // 'catalyst' | 'ripple_nexus' | 'system'
  adminId   String   // The user who performed the action
  action    String   // e.g., 'INVOICE_CREATED', 'PRICING_EDITED', 'FILE_UPLOADED'
  entity    String   // e.g., 'Invoice', 'RnClient'
  entityId  String   // ID of the mutated record
  changes   Json?    // { before: {...}, after: {...} }
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([entity, entityId])
  @@index([adminId])
}
