// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClientType {
  FRESHER
  MID_CAREER
  EXECUTIVE
  EXECUTIVE_PLUS
  AGENCY_CLIENT // NEW — Ripple Nexus agency service clients
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
  VIEWER
  PROJECT_MANAGER
  DESIGNER
  BILLING
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(EDITOR)
  brandAccess  String[]  @default(["catalyst", "ripple_nexus"]) // RBAC brand isolation
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
  EXPIRED
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  // Client Info
  clientName  String
  clientEmail String
  clientPhone String
  clientType  ClientType
  country     String
  companyName String?

  // Currency
  currency       String
  currencySymbol String
  exchangeRate   Float

  // ── Line items (new flexible model) ──────────
  // JSON array of { id, description, qty, unitPrice, lineTotal }
  lineItems Json @default("[]")

  // Invoice-level adjustments
  discountRate   Float @default(0) // % discount applied on subtotal
  taxRate        Float @default(0) // % tax applied after discount
  discountAmount Float @default(0) // computed
  taxAmount      Float @default(0) // computed

  // ── Legacy service fields (backward compat) ──
  resumeBaseInr        Float @default(0)
  linkedinBaseInr      Float @default(0)
  coverLetterBaseInr   Float @default(0)
  resumeConverted      Float @default(0)
  linkedinConverted    Float @default(0)
  coverLetterConverted Float @default(0)

  // Totals
  subtotalConverted      Float
  processingFeeRate      Float
  processingFeeConverted Float
  totalPayable           Float

  // Revisions
  revisionCount  Int   @default(0)
  revisionCharge Float @default(0)

  // Meta
  notes         String?
  customPricing Boolean @default(false)

  // Payment
  status            InvoiceStatus @default(PENDING)
  razorpayLinkId    String?
  razorpayLinkUrl   String?
  razorpayPaymentId String?
  paidAt            DateTime?

  // Dates
  invoiceDate DateTime @default(now())
  dueDate     DateTime

  // Payment gateway
  paymentGateway   String  @default("RAZORPAY") // "RAZORPAY" | "PAYPAL"
  paypalInvoiceId  String?
  paypalPaymentUrl String?

  // Split / installment payment
  installmentPlan  Boolean @default(false)
  installmentCount Int     @default(1) // 1 = single, 2 = two parts, 3 = three parts
  installments     Json    @default("[]") // Installment[]

  // Email & Automation
  emailSentAt            DateTime?
  emailResendCount       Int       @default(0)
  abandonedCheckoutLevel Int       @default(0) // 0=none, 1=1hr, 2=24hr, 3=72hr
  expiresAt              DateTime?

  // ── Brand context (NEW — additive, @default ensures all existing invoices = 'catalyst') ──
  // 'catalyst'     → Career Booster invoice — Catalyst branding, Catalyst email theme
  // 'ripple_nexus' → Agency invoice — Ripple Nexus branding, RN email theme
  brandId     String  @default("catalyst")
  rnServiceId String? // For Ripple Nexus: which service module this invoice is for

  // ── Relational Data (New Phase 3) ──────────
  invoiceLineItems    InvoiceLineItem[]
  invoiceInstallments InvoiceInstallment[]
  clientLinks         InvoiceClientLink[]

  // ── Sales funnel attribution (additive, nullable for legacy rows) ──
  sourceChannel       String? // INQUIRE | CHECKOUT | APPLY | ADMIN
  salesInquiryId      String?
  checkoutSessionId   String?
  proposalId          String?
  salesInquiry        SalesInquiry?   @relation("InquiryInvoice", fields: [salesInquiryId], references: [id], onDelete: SetNull)
  checkoutSession     CheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  proposal            Proposal?       @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
  @@index([clientType])
  @@index([clientEmail])
  @@index([paymentGateway])
  @@index([sourceChannel])
  @@index([salesInquiryId])
  @@index([checkoutSessionId])
}

model ExchangeRateCache {
  id             String   @id @default(cuid())
  baseCurrency   String   @default("INR")
  targetCurrency String
  rate           Float
  cachedAt       DateTime @default(now())
  expiresAt      DateTime

  @@unique([baseCurrency, targetCurrency])
}

// ─────────────────────────────────────────────────────────────────────────────
// CAREER BOOSTER MODULE
// ─────────────────────────────────────────────────────────────────────────────

enum CareerPackage {
  RESUME
  LINKEDIN
  COVER_LETTER
  FULL
}

// Dynamic services — seeded; new clients use CareerClientService
model CareerService {
  id       String  @id @default(cuid())
  slug     String  @unique // RESUME | COVER_LETTER | LINKEDIN | PORTFOLIO | FULL_PACKAGE
  name     String
  formType String? // career_profile | linkedin_profile | portfolio_website | null

  clients CareerClientService[]
}

model CareerClientService {
  id        String   @id @default(cuid())
  clientId  String
  serviceId String
  status    String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, IN_REVIEW, COMPLETED
  timeline  Json     @default("[]") // Log of events for this specific service
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt // Added for V2

  client  CareerClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service CareerService @relation(fields: [serviceId], references: [id])

  @@unique([clientId, serviceId])
  @@index([clientId])
}

enum CareerStatus {
  NOT_STARTED
  SUBMITTED
  UNDER_PROCESS
  DRAFT_SENT
  REVISION_REQUESTED
  COMPLETED
}

model CareerClient {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  phone              String?
  packageType        CareerPackage? // deprecated: use services relation
  status             CareerStatus   @default(NOT_STARTED)
  amountPaid         Float          @default(0)
  currency           String         @default("INR")
  razorpayPaymentId  String?        @unique
  razorpayOrderId    String?
  magicToken         String?
  magicTokenExpiry   DateTime?
  pinHash            String? // HMAC-SHA256 of 6-digit PIN
  lastLoginAt        DateTime?
  invoiceId          String?
  notes              String?
  expectedDeliveryAt DateTime?
  draftSentAt        DateTime?
  completedAt        DateTime?
  firstCompletedAt   DateTime? // set once on first COMPLETED — revision window is always relative to this
  slaDeadline        DateTime?
  slaStatus          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  waitingOn          String         @default("AGENCY") // "AGENCY" | "CLIENT"

  // Phase 4: Lifecycle & Archival
  lifecycleStatus  String    @default("ACTIVE") // ACTIVE | ARCHIVED | EXPIRED | CANCELLED
  archivedAt       DateTime?
  archiveReason    String?
  reEngagedAt        DateTime?
  reEngagedFrom      String?
  lastAdminReplyAt   DateTime?

  // ── Sales funnel attribution (additive) ──
  sourceChannel      String?  // 'INQUIRE' | 'CHECKOUT' | 'APPLY' | 'ADMIN' — how this client was acquired
  checkoutSessionId  String?  // Links back to the CheckoutSession that created this client
  salesInquiryId     String?  // Links back to the SalesInquiry (for /inquire flow)

  forms        CareerFormSubmission[]
  deliverables CareerDeliverable[]
  emailLogs    CareerEmailLog[]
  activityLogs CareerActivityLog[]
  revisions    CareerRevision[]
  comments     CareerComment[]
  services     CareerClientService[]
  messages     CareerMessage[]
  deleteOtp    CareerDeleteOtp?
  bugReports   BugReport[]

  // Upgrade Migration Relations
  invoiceLinks          InvoiceClientLink[]
  upgradeHistory        ClientUpgradeHistory[]
  Feedback              Feedback?
  Review                Review?
  ClientHealthScore     ClientHealthScore?
  ConversationReadState ConversationReadState?
  ClientNotification    ClientNotification[]

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([email])
  @@index([packageType])
  @@index([lifecycleStatus])
  @@index([completedAt])
  @@index([contactId])
}

model CareerFormSubmission {
  id          String   @id @default(cuid())
  clientId    String
  formType    String
  formData    Json
  version     Int      @default(1)
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, formType])
}

model CareerDeliverable {
  id             String    @id @default(cuid())
  clientId       String
  label          String
  fileUrl        String
  publicId       String
  fileType       String
  mimeType       String
  sizeBytes      Int       @default(0)
  originalName   String    @default("")
  fileCategory   String    @default("final") // "draft" | "final"
  resourceType   String    @default("raw") // "raw" | "image" | "video"
  uploadedBy     String
  emailSent      Boolean   @default(false)
  approvalStatus String    @default("PENDING")
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, fileCategory])
}

model CareerEmailLog {
  id       String   @id @default(cuid())
  clientId String
  trigger  String
  resendId String?
  status   String   @default("sent")
  metadata Json?
  sentAt   DateTime @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, trigger])
  @@index([clientId])
  @@index([clientId, trigger, status])
}

model CareerActivityLog {
  id          String   @id @default(cuid())
  clientId    String
  action      String
  performedBy String   @default("system")
  metadata    Json?
  createdAt   DateTime @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerFormSchema {
  id        String   @id @default(cuid())
  formType  String   @unique
  schema    Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model CareerRevision {
  id          String  @id @default(cuid())
  clientId    String
  requestedBy String  @default("client") // "client" | "admin"
  note        String
  fileLabel   String? // which deliverable this relates to
  status      String  @default("PENDING") // PENDING | APPROVED | DENIED
  adminNote   String?

  // Phase 3: Per-service tracking & Paid revisions
  serviceSlug       String? // e.g., 'RESUME', 'LINKEDIN'
  chargeStatus      String  @default("FREE") // "FREE" | "PENDING_PAYMENT" | "PAID"
  invoiceId         String? // Links to the generated invoice for paid revisions
  clientStatusBefore String? // careerClient.status at the moment this revision was created — used to restore state on DENY

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerComment {
  id             String    @id @default(cuid())
  clientId       String
  authorType     String    @default("client") // "client" | "admin"
  authorName     String
  content        String
  attachments    Json? // {name,url,mimeType,size}[]
  readByAdmin    Boolean   @default(false)
  readByClient   Boolean   @default(false)
  readByAdminAt  DateTime?
  readByClientAt DateTime?
  annotationX    Float?
  annotationY    Float?
  annotationPage Int?
  isInternalOnly Boolean   @default(false)
  editedAt       DateTime?
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerMessage {
  id             String    @id @default(cuid())
  clientId       String
  authorType     String    @default("client") // "client" | "admin"
  authorName     String
  content        String
  isInternalOnly Boolean   @default(false)
  readByAdmin    Boolean   @default(false)
  readByClient   Boolean   @default(false)
  readByAdminAt  DateTime?
  readByClientAt DateTime?
  createdAt      DateTime  @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model CareerDeleteOtp {
  id        String   @id @default(cuid())
  clientId  String   @unique
  otpHash   String // SHA-256 of 6-digit OTP
  expiresAt DateTime
  createdAt DateTime @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// RELATIONAL INVOICE STRUCTURES (PHASE 3)
// ─────────────────────────────────────────────────────────────────────────────

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  qty         Int
  unitPrice   Float
  lineTotal   Float
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceInstallment {
  id              String    @id @default(cuid())
  invoiceId       String
  seq             Int // e.g. 1, 2, 3
  amount          Float
  dueDate         DateTime
  status          String    @default("PENDING") // PENDING, PAID, CANCELLED, EXPIRED
  paidAt          DateTime?
  paypalInvoiceId String?   // PayPal invoice ID for this installment — enables direct webhook lookup
  createdAt       DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paypalInvoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RELIABILITY & QUEUES (PHASE 2)
// ─────────────────────────────────────────────────────────────────────────────

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String // e.g., 'RAZORPAY', 'PAYPAL'
  eventId   String   @unique // The unique ID from the provider (e.g., razorpay_payment_id or event_id)
  eventType String // e.g., 'payment.captured'
  payload   Json // The raw payload
  status    String   @default("PENDING") // 'PENDING', 'PROCESSED', 'FAILED'
  error     String?
  createdAt DateTime @default(now())

  @@index([provider, eventId])
}

model EmailQueue {
  id        String   @id @default(cuid())
  to        String
  trigger   String
  clientId  String?
  data      Json? // Email template data
  status    String   @default("PENDING") // 'PENDING', 'PROCESSING', 'SENT', 'FAILED'
  error     String?
  attempts  Int      @default(0)
  nextRunAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextRunAt])
  @@index([clientId, trigger])
}

// ─────────────────────────────────────────────────────────────────────────────
// RIPPLE NEXUS MODULE  [NEW — all tables below are additive, zero impact on existing]
// Career* tables above are 100% untouched.
// ─────────────────────────────────────────────────────────────────────────────

// Service modules — defines the workflow stages and policies for each RN service
model RnServiceModule {
  id             String   @id @default(cuid())
  slug           String   @unique // 'web_development' | 'seo_optimization' | 'ai_automation' | 'branding' | 'saas_development' | 'consulting' | 'marketing'
  name           String // "Website Development"
  workflowStages Json // string[] — ordered stage names e.g. ["DISCOVERY","WIREFRAME","DESIGN","DEVELOPMENT","QA","LAUNCHED"]
  revisionLimit  Int      @default(3)
  revisionCharge Float    @default(0) // extra revision charge in INR base
  defaultSlaDays Int      @default(30)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clients RnClient[]

  @@index([slug])
}

// Ripple Nexus agency clients — completely separate from CareerClient

model RnOrganization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  RnOrganizationMember[]
  projects RnClient[]
}

model RnOrganizationMember {
  id               String    @id @default(cuid())
  orgId            String
  name             String
  email            String    @unique
  role             String    @default("MEMBER") // "ADMIN" | "MEMBER"
  magicToken       String?
  magicTokenExpiry DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization RnOrganization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([orgId])
}

model RnClient {
  id              String  @id @default(cuid())
  name            String
  email           String  @unique
  phone           String?
  country         String?
  companyName     String?
  serviceModuleId String
  organizationId  String?

  // Workflow state
  currentStage    String   @default("NOT_STARTED")
  completedStages Json     @default("[]") // string[]
  stageEnteredAt  DateTime @default(now())

  // Payment reference
  invoiceId  String?
  amountPaid Float   @default(0)
  currency   String  @default("INR")

  // Portal access
  magicToken       String?
  magicTokenExpiry DateTime?
  pinHash          String? // HMAC-SHA256 of 6-digit PIN
  lastLoginAt      DateTime?

  // Project timeline
  expectedDeliveryAt DateTime?
  completedAt        DateTime?
  notes              String?
  slaDeadline        DateTime?
  slaStatus          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  waitingOn          String    @default("AGENCY") // "AGENCY" | "CLIENT"

  // Phase 4: Lifecycle & Archival
  lifecycleStatus  String    @default("ACTIVE") // ACTIVE | ARCHIVED | EXPIRED | CANCELLED
  archivedAt       DateTime?
  archiveReason    String?
  lastAdminReplyAt DateTime?

  organization          RnOrganization?        @relation(fields: [organizationId], references: [id])
  serviceModule         RnServiceModule        @relation(fields: [serviceModuleId], references: [id])
  forms                 RnFormSubmission[]
  deliverables          RnDeliverable[]
  revisions             RnRevision[]
  messages              RnMessage[]
  emailLogs             RnEmailLog[]
  activityLogs          RnActivityLog[]
  deleteOtp             RnDeleteOtp?
  milestones            RnProjectMilestone[]
  comments              RnComment[]
  Feedback              Feedback?
  Review                Review?
  ClientHealthScore     ClientHealthScore?
  ConversationReadState ConversationReadState?
  ClientNotification    ClientNotification[]

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([serviceModuleId, currentStage])
  @@index([lifecycleStatus])
  @@index([contactId])
}

model RnFormSubmission {
  id          String   @id @default(cuid())
  clientId    String
  formSlug    String // 'discovery' | 'requirements' | 'feedback'
  formData    Json
  version     Int      @default(1)
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnDeliverable {
  id             String    @id @default(cuid())
  clientId       String
  label          String
  fileUrl        String
  publicId       String
  fileType       String
  mimeType       String
  sizeBytes      Int       @default(0)
  originalName   String    @default("")
  fileCategory   String    @default("final") // 'draft' | 'milestone' | 'final'
  resourceType   String    @default("raw") // 'raw' | 'image' | 'video'
  stageContext   String? // which workflow stage this belongs to
  uploadedBy     String
  emailSent      Boolean   @default(false)
  approvalStatus String    @default("PENDING")
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, fileCategory])
}

model RnRevision {
  id           String   @id @default(cuid())
  clientId     String
  requestedBy  String   @default("client") // 'client' | 'admin'
  note         String
  fileLabel    String?
  status       String   @default("PENDING") // 'PENDING' | 'APPROVED' | 'DENIED'
  adminNote    String?
  chargeAmount Float    @default(0) // 0 = free revision within limit
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnComment {
  id             String    @id @default(cuid())
  clientId       String
  deliverableId  String?
  authorType     String    @default("client") // "client" | "admin"
  authorName     String
  content        String
  attachments    Json? // {name,url,mimeType,size}[]
  annotationX    Float?
  annotationY    Float?
  annotationPage Int?
  isInternalOnly Boolean   @default(false)
  readByAdmin    Boolean   @default(false)
  readByClient   Boolean   @default(false)
  readByAdminAt  DateTime?
  readByClientAt DateTime?
  createdAt      DateTime  @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([deliverableId])
}

model RnMessage {
  id             String    @id @default(cuid())
  clientId       String
  authorType     String    @default("client") // 'client' | 'admin'
  authorName     String
  content        String
  isInternalOnly Boolean   @default(false)
  attachments    Json? // {name,url,mimeType,size}[]
  readByAdmin    Boolean   @default(false)
  readByClient   Boolean   @default(false)
  readByAdminAt  DateTime?
  readByClientAt DateTime?
  createdAt      DateTime  @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnEmailLog {
  id       String   @id @default(cuid())
  clientId String
  trigger  String
  resendId String?
  status   String   @default("sent") // 'sent' | 'failed'
  metadata Json?
  sentAt   DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, trigger, status])
}

model RnActivityLog {
  id          String   @id @default(cuid())
  clientId    String
  action      String
  performedBy String   @default("system")
  metadata    Json?
  createdAt   DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model RnDeleteOtp {
  id        String   @id @default(cuid())
  clientId  String   @unique
  otpHash   String // SHA-256 of 6-digit OTP
  expiresAt DateTime
  createdAt DateTime @default(now())

  client RnClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// ENTERPRISE AUDIT & SECURITY (PHASE 3)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String // 'catalyst' | 'ripple_nexus' | 'system'
  adminId   String // The user who performed the action
  action    String // e.g., 'INVOICE_CREATED', 'PRICING_EDITED', 'FILE_UPLOADED'
  entity    String // e.g., 'Invoice', 'RnClient'
  entityId  String // ID of the mutated record
  changes   Json? // { before: {...}, after: {...} }
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([entity, entityId])
  @@index([adminId])
}

model AdminNote {
  id        String   @id @default(cuid())
  clientId  String // Works for both CareerClient and RnClient
  adminId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([adminId])
}

model Notification {
  id        String   @id @default(cuid())
  adminId   String
  title     String
  message   String
  link      String? // Optional URL to redirect when clicked
  isRead    Boolean  @default(false)
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, ERROR
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([isRead])
}

model RnProjectMilestone {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  description String?
  order       Int
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, IN_REVIEW, APPROVED
  dueDate     DateTime?
  approvedAt  DateTime?

  client RnClient        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks  RnProjectTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model RnProjectTask {
  id          String  @id @default(cuid())
  milestoneId String
  title       String
  isCompleted Boolean @default(false)

  milestone RnProjectMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([milestoneId])
}

// ─────────────────────────────────────────────────────────────────────────────
// UPGRADE & MIGRATION ARCHITECTURE (PHASE 3.5)
// ─────────────────────────────────────────────────────────────────────────────

model InvoiceClientLink {
  id        String   @id @default(cuid())
  clientId  String
  invoiceId String   @unique
  purpose   String   @default("INITIAL") // 'INITIAL', 'UPGRADE', 'REVISION'
  createdAt DateTime @default(now())

  client  CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([clientId, invoiceId])
  @@index([clientId])
}

model ClientUpgradeHistory {
  id               String   @id @default(cuid())
  clientId         String
  previousServices Json // Array of service slugs before upgrade
  addedServices    Json // Array of newly unlocked service slugs
  invoiceId        String
  createdAt        DateTime @default(now())

  client CareerClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 3: FEEDBACK, ANALYTICS, & COMMUNICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Feedback {
  id             String  @id @default(cuid())
  careerClientId String? @unique
  rnClientId     String? @unique

  serviceType     String
  rating          Int // 1-5
  npsScore        Int // 0-10
  communication   Int // 1-5
  deliveryQuality Int // 1-5
  turnaroundTime  Int // 1-5
  comments        String?

  deliveryDurationDays Int?
  revisionCount        Int?

  createdAt DateTime @default(now())

  careerClient CareerClient? @relation(fields: [careerClientId], references: [id], onDelete: Cascade)
  rnClient     RnClient?     @relation(fields: [rnClientId], references: [id], onDelete: Cascade)
}

model Review {
  id             String  @id @default(cuid())
  careerClientId String? @unique
  rnClientId     String? @unique

  rating      Int
  testimonial String
  designation String?
  company     String?
  linkedinUrl String?
  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  careerClient CareerClient? @relation(fields: [careerClientId], references: [id], onDelete: Cascade)
  rnClient     RnClient?     @relation(fields: [rnClientId], references: [id], onDelete: Cascade)
}

model ClientHealthScore {
  id             String  @id @default(cuid())
  careerClientId String? @unique
  rnClientId     String? @unique

  score         Float // 0-100
  satisfaction  Float?
  responseSpeed Float?
  revisionRisk  Float?

  status String // 'EXCELLENT', 'HEALTHY', 'ATTENTION_NEEDED', 'AT_RISK'

  lastCalculatedAt DateTime @default(now())

  careerClient CareerClient? @relation(fields: [careerClientId], references: [id], onDelete: Cascade)
  rnClient     RnClient?     @relation(fields: [rnClientId], references: [id], onDelete: Cascade)
}

model ConversationReadState {
  id             String  @id @default(cuid())
  careerClientId String? @unique
  rnClientId     String? @unique

  unreadByAdmin  Int      @default(0)
  unreadByClient Int      @default(0)
  lastMessageAt  DateTime @default(now())
  lastMessageBy  String   @default("client") // 'client' | 'admin'

  adminSlaDeadline DateTime?
  adminSlaEvent    String? // e.g. 'NEW_MESSAGE', 'REVISION_REQUEST'

  careerClient CareerClient? @relation(fields: [careerClientId], references: [id], onDelete: Cascade)
  rnClient     RnClient?     @relation(fields: [rnClientId], references: [id], onDelete: Cascade)

  @@index([unreadByAdmin])
  @@index([unreadByClient])
  @@index([lastMessageAt])
}

model ClientNotification {
  id             String  @id @default(cuid())
  careerClientId String?
  rnClientId     String?

  title   String
  message String
  link    String?
  isRead  Boolean @default(false)
  type    String  @default("INFO")

  createdAt DateTime @default(now())

  careerClient CareerClient? @relation(fields: [careerClientId], references: [id], onDelete: Cascade)
  rnClient     RnClient?     @relation(fields: [rnClientId], references: [id], onDelete: Cascade)

  @@index([careerClientId, isRead])
  @@index([rnClientId, isRead])
}

// ─────────────────────────────────────────────────────────────────────────────
// REGISTRY & IDENTITY MODELS
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id            String   @id @default(cuid())
  displayId     String?  @unique // e.g. LD-1002
  name          String
  email         String?  @unique
  phone         String?
  companyName   String?
  country       String?
  city          String?
  timezone      String?
  industry      String?
  jobTitle      String?
  linkedinUrl   String?
  contactSource String? // EXCEL_IMPORT, CATALYST, RIPPLE_NEXUS, MANUAL, WEBSITE, LINKEDIN, REFERRAL
  status        String   @default("ACTIVE") // ACTIVE, MERGED, ARCHIVED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mergedIntoContactId String?
  mergedIntoContact   Contact?  @relation("ContactMerges", fields: [mergedIntoContactId], references: [id])
  mergedFromContacts  Contact[] @relation("ContactMerges")

  careerClients CareerClient[]
  rnClients     RnClient[]

  flywheelProfile FlywheelProfile?
  salesInquiries        SalesInquiry[]

  sourceMergeReviews    ContactMergeReview[]   @relation("SourceContact")
  targetMergeReviews    ContactMergeReview[]   @relation("TargetContact")
  flywheelCampaignLeads FlywheelCampaignLead[]
  FlywheelActionCard    FlywheelActionCard[]

  @@index([email])
  @@index([phone])
  @@index([contactSource])
  @@index([status])
  @@index([displayId])
}

model ContactMergeReview {
  id              String   @id @default(cuid())
  sourceContactId String
  targetContactId String
  confidenceScore Int
  reason          String
  status          String   @default("PENDING") // "PENDING" | "MERGED" | "REJECTED_NEW" | "IGNORED"
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceContact Contact @relation("SourceContact", fields: [sourceContactId], references: [id], onDelete: Cascade)
  targetContact Contact @relation("TargetContact", fields: [targetContactId], references: [id], onDelete: Cascade)

  @@index([sourceContactId])
  @@index([targetContactId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// FLYWHEEL PROFILE & READ MODELS
// ─────────────────────────────────────────────────────────────────────────────

model FlywheelProfile {
  id             String  @id @default(cuid())
  contactId      String  @unique
  leadStatus     String  @default("NEW")
  lifecycleStage String  @default("LEAD")
  optInStatus    Boolean @default(true)
  optInIp        String?
  optInSource    String?
  referralCode   String? @unique
  ownerId        String? // AdminUser ID reference (soft link)

  engagementScore   Int?     @default(0)
  referralScore     Int?     @default(0)
  reactivationScore Int?     @default(0)
  totalRevenue      Decimal? @default(0.00) @db.Decimal(12, 2)
  dealValue         Decimal? @default(0.00) @db.Decimal(12, 2)
  invoiceCount      Int?     @default(0)

  lastInvoiceDate DateTime?
  lastServiceDate DateTime?
  lastCampaignAt  DateTime?
  lastContactedAt DateTime?
  nextActionDate  DateTime?

  servicesPurchased Json?
  tags              Json?

  referredById String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact    Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  referredBy FlywheelProfile?  @relation("Referrals", fields: [referredById], references: [id])
  referrals  FlywheelProfile[] @relation("Referrals")

  @@index([contactId])
  @@index([lifecycleStage])
  @@index([leadStatus])
  @@index([referralCode])
}

model ProcessedEvent {
  id          String   @id @default(cuid())
  eventId     String
  eventType   String
  processedAt DateTime @default(now())

  @@unique([eventType, eventId])
  @@index([processedAt])
}

model MigrationRun {
  id                   String    @id
  type                 String
  status               String
  startedAt            DateTime
  completedAt          DateTime?
  recordsProcessed     Int       @default(0)
  contactsCreated      Int       @default(0)
  contactsMatched      Int       @default(0)
  manualReviewsCreated Int       @default(0)
  errors               Int       @default(0)
  metadata             Json?
}

// ─────────────────────────────────────────────────────────────────────────────
// FLYWHEEL MARKETING AUTOMATION & CRM (INDUSTRY READY)
// ─────────────────────────────────────────────────────────────────────────────

model FlywheelCampaign {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("ONE_OFF") // "ONE_OFF", "DRIP"
  status    String   @default("DRAFT") // "DRAFT", "ACTIVE", "PAUSED", "COMPLETED"
  brandId   String   @default("catalyst")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps FlywheelCampaignStep[]
  leads FlywheelCampaignLead[]

  @@index([status])
  @@index([brandId])
}

model FlywheelCampaignStep {
  id          String   @id @default(cuid())
  campaignId  String
  subject     String
  contentHtml String   @db.Text
  delayHours  Int      @default(0)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign     FlywheelCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadsCurrent FlywheelCampaignLead[] @relation("CurrentStep")

  @@index([campaignId])
}

model FlywheelCampaignLead {
  id              String   @id @default(cuid())
  campaignId      String
  contactId       String
  currentStepId   String?
  status          String   @default("PENDING") // "PENDING", "ACTIVE", "COMPLETED", "UNSUBSCRIBED", "BOUNCED"
  nextExecutionAt DateTime @default(now())
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign    FlywheelCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentStep FlywheelCampaignStep? @relation("CurrentStep", fields: [currentStepId], references: [id])
  events      FlywheelEmailEvent[]

  @@unique([campaignId, contactId])
  @@index([status, nextExecutionAt]) // Critical for Cron Job querying
  @@index([contactId])
}

model FlywheelEmailEvent {
  id             String   @id @default(cuid())
  campaignLeadId String
  eventType      String // "SENT", "DELIVERED", "OPEN", "CLICK", "BOUNCE", "UNSUBSCRIBE"
  metadata       Json? // e.g., URL clicked, bounce reason, user agent
  createdAt      DateTime @default(now())

  campaignLead FlywheelCampaignLead @relation(fields: [campaignLeadId], references: [id], onDelete: Cascade)

  @@index([campaignLeadId])
  @@index([eventType])
}

model UnsubscribeList {
  id        String   @id @default(cuid())
  email     String
  brandId   String   @default("catalyst")
  reason    String?
  createdAt DateTime @default(now())

  @@unique([email, brandId])
  @@index([email])
}

// ─── ACTION ENGINE (NEW V5) ───

model FlywheelActionCard {
  id               String    @id @default(cuid())
  contactId        String
  type             String // UPSELL, REFERRAL, REVIEW, RISK, RETENTION
  title            String
  reason           String
  confidence       Int       @default(0) // 0-100
  revenuePotential Decimal   @default(0.00) @db.Decimal(12, 2)
  status           String    @default("PENDING") // PENDING, APPROVED, DISMISSED, EXECUTED
  suggestedAction  String // The action identifier (e.g., "SEND_EMAIL_TEMPLATE_X")
  actionData       Json? // Payload needed to execute the action
  priority         Int       @default(0) // Higher = top of the feed
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, status])
  @@index([status, priority(desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES INQUIRY & SELF-SERVICE CHECKOUT (Flow A + Flow B)
// ─────────────────────────────────────────────────────────────────────────────

enum InquiryChannel {
  INQUIRE
  APPLY
  MANUAL
  IMPORT
}

enum InquiryStatus {
  NEW
  UNDER_REVIEW
  QUALIFIED
  APPROVED
  REJECTED
  REQUEST_INFO
  PROPOSAL_SENT
  INVOICE_SENT
  CONVERTED
  LOST
}

enum InquiryPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum CheckoutChannel {
  APPLY
  CHECKOUT
  ADMIN
  MANUAL
}

enum CheckoutSessionStatus {
  DRAFT
  INVOICE_CREATED
  PAID
  ABANDONED
  EXPIRED
}

model SalesInquiry {
  id                  String           @id @default(cuid())
  displayId           String           @unique
  contactId           String?
  status              InquiryStatus    @default(NEW)
  priority            InquiryPriority  @default(MEDIUM)
  channel             InquiryChannel   @default(INQUIRE)
  name                String
  email               String
  phone               String?
  countryCode         String
  countryName         String
  requirementType     String
  servicesRequested   Json             @default("[]")
  requirementNotes    String?          @db.Text
  qualificationScore  Int?
  assignedToId        String?
  sourceUrl           String?
  utmJson             Json?
  flywheelProfileId   String?
  convertedInvoiceId  String?
  convertedClientId   String?
  legacyMetadata      Json?
  closedAt            DateTime?

  // ── Sales funnel redesign (additive) ──
  autoQualScore       Int?             // Computed 0-100 score based on requirement type, country, services
  qualificationNotes  String?          @db.Text  // Admin notes during qualification
  firstResponseAt     DateTime?        // When admin first reviewed this inquiry
  slaBreachedAt       DateTime?        // If first response > 24h SLA

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  contact    Contact?             @relation(fields: [contactId], references: [id], onDelete: SetNull)
  proposals  Proposal[]
  activities InquiryActivityLog[]
  invoices   Invoice[]            @relation("InquiryInvoice")
  checkoutSessions CheckoutSession[]

  @@index([status])
  @@index([channel])
  @@index([email])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([contactId])
}

model Proposal {
  id               String         @id @default(cuid())
  inquiryId        String
  version          Int            @default(1)
  status           ProposalStatus @default(DRAFT)
  title            String
  scopeSummary     String         @db.Text
  deliverables     Json           @default("[]")
  lineItems        Json           @default("[]")
  revisionLimits   Json?          // E.g., { "Resume": 2, "LinkedIn": 1 }
  deliveryTimeline Json?          // E.g., { "EstimatedDays": 5, "Description": "5 business days" }
  currency         String
  currencySymbol   String         @default("$")
  subtotal         Float
  discount         Float          @default(0)
  tax              Float          @default(0)
  total            Float
  validUntil       DateTime
  sentAt           DateTime?
  viewedAt         DateTime?
  respondedAt      DateTime?
  acceptedByEmail  String?
  clientNotes      String?        @db.Text  // Client's notes when accepting/declining
  publicToken      String         @unique @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  inquiry          SalesInquiry      @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  invoices         Invoice[]
  checkoutSessions CheckoutSession[] // A proposal can generate one or more checkout sessions (e.g., if one expires)

  @@index([inquiryId])
  @@index([status])
  @@index([publicToken])
}

model InquiryActivityLog {
  id          String   @id @default(cuid())
  inquiryId   String
  action      String
  fromStatus  String?
  toStatus    String?
  note        String?  @db.Text
  adminId     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  inquiry SalesInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([createdAt])
}

model CheckoutSession {
  id                    String                @id @default(cuid())
  channel               CheckoutChannel       @default(CHECKOUT)
  contactId             String?
  salesInquiryId        String?
  proposalId            String?
  invoiceId             String?
  packageSlug           String
  services              Json                  @default("[]")
  experienceLevel       ClientType
  pricingSnapshot       Json
  status                CheckoutSessionStatus @default(DRAFT)
  paymentUrl            String?
  abandonedCheckoutLevel Int                  @default(0)
  name                  String
  email                 String
  phone                 String?
  countryCode           String
  countryName           String

  // ── Post-payment tracking (additive) ──
  createdClientId       String?               // The CareerClient created after payment
  portalActivatedAt     DateTime?
  onboardingUrl         String?               // The magic link URL for portal access

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  salesInquiry SalesInquiry? @relation(fields: [salesInquiryId], references: [id], onDelete: SetNull)
  proposal     Proposal?     @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@index([status])
  @@index([email])
  @@index([channel])
  @@index([invoiceId])
  @@index([proposalId])
}

model BugReport {
  id          String   @id @default(cuid())
  clientId    String?
  clientEmail String?
  clientName  String?
  description String   @db.Text
  url         String?
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  adminNotes  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      CareerClient? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([clientId])
}

// System-level email log — covers emails sent via mailer.ts and sales/email.ts
// (proposals, invoices, admin alerts). Career lifecycle emails are in CareerEmailLog.
model SysEmailLog {
  id       String   @id @default(cuid())
  to       String
  subject  String
  trigger  String   // PROPOSAL_SENT | INVOICE_SENT | PROPOSAL_ACCEPTED | PROPOSAL_DECLINED | ADMIN_ALERT
  channel  String   @default("smtp") // smtp | resend
  status   String   @default("sent") // sent | failed
  error    String?  @db.Text
  metadata Json?
  sentAt   DateTime @default(now())

  @@index([sentAt])
  @@index([trigger])
  @@index([to])
}
